params {
    // ── Input ──────────────────────────────────────────────────────────
    input_dir       = null      // Directory with POD5/FAST5 files OR pre-basecalled FASTQ
    input_fastq     = null      // Direct FASTQ input (skip basecalling if provided)
    metadata        = null      // Sample metadata CSV (required for diversity & correlation)
    outdir          = './results'
    sample_id       = 'sample'

    // ── Basecalling (Dorado) ───────────────────────────────────────────
    skip_basecalling    = false
    dorado_model        = 'sup'  // sup, hac, or fast

    // ── QC & Filtering (Chopper) ───────────────────────────────────────
    min_quality     = 10
    min_length      = 500

    // ── Host Removal (Minimap2) ────────────────────────────────────────
    host_reference  = null      // Path to GRCh38 FASTA or minimap2 index
    skip_host_removal = false

    // ── Taxonomy (Kraken2 + Bracken) ───────────────────────────────────
    kraken2_db      = null      // Path to Kraken2 database directory
    bracken_read_length = 250   // pre-built databases ship 100/150/200/250/300 bp only
    bracken_level   = 'S'       // S=species, G=genus, F=family
    bracken_threshold   = 10

    // ── Functional Profiling (Prodigal + eggNOG-mapper) ────────────────
    skip_functional = false
    eggnog_db       = null      // Path to eggNOG database directory

    // ── Diversity Analysis ─────────────────────────────────────────────
    skip_diversity  = false
    fdr_alpha       = 0.05
    fdr_ancombc     = 0.2

    // ── LEfSe ──────────────────────────────────────────────────────────
    skip_lefse      = false
    lda_threshold   = 2.0

    // ── MaAsLin2 Biomarker Correlation ─────────────────────────────────
    skip_maaslin2   = false
    fixed_effects   = 'diagnosis,age,sex'
    reference_level = 'neurotypical'

    // ── Visualization ──────────────────────────────────────────────────
    skip_visualization = false

    // ── Resources ──────────────────────────────────────────────────────
    max_cpus        = 16
    max_memory      = '64.GB'
}

// ── Process defaults ───────────────────────────────────────────────────
process {
    errorStrategy = 'retry'
    maxRetries    = 1

    withLabel: 'process_low' {
        cpus   = 4
        memory = '8.GB'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '16.GB'
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = '32.GB'
    }
    withLabel: 'process_high_memory' {
        cpus   = 16
        memory = '64.GB'
    }
}

// ── Docker enabled by default ──────────────────────────────────────────
docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

// ── Profiles ───────────────────────────────────────────────────────────
profiles {
    standard {
        docker.enabled = true
    }
    local {
        docker.enabled = true
        params.max_cpus   = 8
        params.max_memory = '16.GB'
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// ── Reports ────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}
